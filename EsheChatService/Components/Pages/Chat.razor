@page "/"
@page "/chat"
@page "/chat/{SessionId:guid}"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.SignalR.Client
@using Microsoft.AspNetCore.Http.Connections
@using System.Diagnostics
@inject IJSRuntime JS

@using EsheChatService.Shared.Icons
@using EsheChatService.Services
@using EsheChatService.Models
@using EsheChatService.Services.Chat.Strategies
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.EntityFrameworkCore
@using Markdig
@using EsheChatService.Services.Repositories
@using EsheChatService.Services.User

@inject ChatService ChatService
@inject IChatStrategyFactory StrategyFactory
@inject ChatSessionManager SessionManager
@inject NavigationManager Nav
@inject ICurrentUser CurrentUser
@using Microsoft.Extensions.DependencyInjection
@inject IServiceScopeFactory ScopeFactory
@inject ToastService ToastService
@inject ILogger<Chat> Logger
@inject IHttpContextAccessor HttpContextAccessor

@implements IAsyncDisposable

<div class="chat-container">
    <div class="chat-header" style="display: flex; justify-content: space-between; align-items: center; padding: 12px 20px; border-bottom: 1px solid var(--border-color, #e5e7eb);">
        <h3 style="margin: 0; font-size: 1.1rem; font-weight: 600;">@(SessionManager.ActiveSession?.Title ?? "New Chat")</h3>
        <div class="model-selector" style="display: flex; align-items: center; gap: 8px;">
            <label style="font-size: 0.8rem; color: #6b7280; margin: 0;">Model:</label>
            <select class="form-select form-select-sm" @bind="_selectedModelId" disabled="@(_isSending || _isStreaming || IsReadOnly())" style="font-size: 0.85rem; border-radius: 6px; padding: 4px 8px; width: auto; max-width: 220px;">
                @foreach (var opt in StrategyFactory.GetAvailableModels())
                {
                    <option value="@opt.ModelId">@opt.DisplayName (@opt.Provider)</option>
                }
            </select>
        </div>
    </div>

    @if (SessionManager.ActiveSession == null)
    {
        <div class="chat-empty-state">
            <h1>How can I help you?</h1>
            <p>Start a new conversation by typing below.</p>
        </div>
    }
    else
    {

        <ul class="chat-messages" @ref="_messagesRef" @onscroll="OnMessagesScrolled">
            @foreach (var msg in SessionManager.ActiveSession.Messages)
            {
                var roleClass = msg.Role.ToString().ToLower();
                var lastAssistant = GetLastAssistantMessage();
                var isLastAssistant = msg == lastAssistant;

                <li class="message-wrapper @roleClass">
                            <div class="avatar @roleClass">
                                @if (msg.Role == ChatRole.User)
                                {
                                    <UserIcon />
                                }
                                else
                                {
                                    <AssistantIcon />
                                }
                            </div>

                    <div class="chat-message @roleClass">
                        <div class="message-content">
                            @if (msg.Role == ChatRole.Assistant)
                            {
                                @((MarkupString)ToHtml(msg.Content))
                            }
                            else
                            {
                                @msg.Content
                            }
                        </div>
                    </div>

                    @if (msg.Role == ChatRole.Assistant)
                    {
                        <div class="message-actions" style="margin-top: 4px; gap: 8px; display: flex;">
                            @if (isLastAssistant && !_isSending && !_assistantTyping && !IsReadOnly())
                            {
                                <button class="btn btn-sm btn-outline-secondary" @onclick="RegenerateLast" style="font-size: 0.75rem; padding: 2px 8px; display: inline-flex; align-items: center; gap: 4px;">
                                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg>
                                    Regenerate
                                </button>
                            }
                            <button class="btn btn-sm btn-outline-secondary" @onclick='() => CopyToClipboard(msg.Content)' style="font-size: 0.75rem; padding: 2px 8px; display: inline-flex; align-items: center; gap: 4px; opacity: 0.7;">
                                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
                                Copy
                            </button>
                        </div>
                    }

                    @if (msg.AiUsage != null)
                    {
                        <div class="token-usage">
                            <span title="Prompt tokens">⬆ @msg.AiUsage.PromptTokens</span>
                            <span title="Completion tokens">⬇ @msg.AiUsage.CompletionTokens</span>
                            <span title="Total tokens">Σ @msg.AiUsage.TotalTokens</span>
                        </div>
                    }

                </li>
            }

            @if (_assistantTyping && !_isStreaming)
            {
                <li class="message-wrapper assistant">
                    <div class="avatar assistant">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2Z"></path><path d="M12 8v8"></path><path d="M8 12h8"></path></svg>
                    </div>
                    <div class="chat-message assistant typing" style="padding: 10px 16px;">
                        <div class="typing-indicator">
                            <div class="dot"></div>
                            <div class="dot"></div>
                            <div class="dot"></div>
                        </div>
                    </div>
                </li>
            }
            <li style="height: 100px; flex-shrink: 0; list-style: none;"></li>
        </ul>

        @if (_showJumpToLatest)
        {
            <button class="jump-to-latest" @onclick="JumpToLatest">↓</button>
        }

    }

    <div class="chat-input">
        <textarea @bind="UserInput"
               @bind:event="oninput"
               placeholder="@(IsReadOnly() ? "Shared session (View Only)" : "Type your message…")"
               disabled="@(_isSending || IsReadOnly())"
               @onkeydown="HandleKeyDown"
               @ref="_chatInputRef"
               rows="1"></textarea>

        @if (_assistantTyping && !_isSending && !IsReadOnly())
        {
            <button class="stop-btn" @onclick="StopGeneration" title="Stop generating">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="6" y="6" width="12" height="12" rx="2" ry="2"></rect></svg>
            </button>
        }
        else
        {
            <button @onclick="Send" disabled="@(string.IsNullOrWhiteSpace(UserInput) || _isSending || IsReadOnly())">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
            </button>
        }
    </div>
</div>

@code {
    [Parameter] public Guid? SessionId { get; set; }

    private string UserInput = "";
    private bool _isSending;
    private bool _assistantTyping;
    private bool _isStreaming;
    private string _selectedModelId = "mistral-large-latest";

    private AiModelOption SelectedModel =>
        StrategyFactory.GetAvailableModels().FirstOrDefault(m => m.ModelId == _selectedModelId)
        ?? StrategyFactory.GetAvailableModels().First(m => m.IsDefault);

    private ElementReference _messagesRef;
    private ElementReference _chatInputRef;
    private bool _showJumpToLatest;
    private bool _suppressPopupOnce;
    private ScrollIntent _scrollIntent = ScrollIntent.None;
    private bool _shouldFocusChatInput = true;
    private CancellationTokenSource? _cts;
    private readonly Stopwatch _streamRenderThrottle = new();

    HubConnection? _hub;
    
    private bool IsReadOnly()
    {
        if (SessionManager.ActiveSession == null) return false;
        return SessionManager.ActiveSession.UserOwnerId != CurrentUser.UserId;
    }


    protected override async Task OnInitializedAsync()
    {
        SessionManager.OnChange += StateHasChanged;

        _hub = new HubConnectionBuilder()
            .WithUrl(Nav.ToAbsoluteUri("/chathub"), options =>
            {
                options.Transports = HttpTransportType.WebSockets;

                // Forward auth cookies so hub Context.User is authenticated
                var httpContext = HttpContextAccessor.HttpContext;
                if (httpContext != null)
                {
                    var cookies = httpContext.Request.Headers["Cookie"].ToString();
                    if (!string.IsNullOrEmpty(cookies))
                    {
                        options.Headers.Add("Cookie", cookies);
                    }
                }
            })
            .WithAutomaticReconnect()
            .Build();

        _hub.On<Guid, string>("AssistantMessageReceived", async (messageId, message) =>
        {
            bool nearBottom = true;
            try { nearBottom = await JS.InvokeAsync<bool>("chatScroll.isNearBottom", _messagesRef); } catch { }
            SessionManager.AddMessageInMemory(ChatRole.Assistant, message, messageId);
            _assistantTyping = false;
            
            if (nearBottom)
            {
                _scrollIntent = ScrollIntent.ForceScroll;
                _showJumpToLatest = false;
            }
            else
            {
                _showJumpToLatest = true;
            }
            await InvokeAsync(StateHasChanged);
        });

        _hub.On<Guid, string>("UserMessageReceived", async (messageId, message) =>
        {
            bool nearBottom = true;
            try { nearBottom = await JS.InvokeAsync<bool>("chatScroll.isNearBottom", _messagesRef); } catch { }
            SessionManager.AddMessageInMemory(ChatRole.User, message, messageId);
            if (nearBottom)
            {
                _scrollIntent = ScrollIntent.ForceScroll;
                _showJumpToLatest = false;
            }
            else
            {
                _showJumpToLatest = true;
            }
            await InvokeAsync(StateHasChanged);
        });


        _hub.On<bool>("AssistantTyping", isTyping =>
        {
            _assistantTyping = isTyping;
            InvokeAsync(StateHasChanged);
        });

        await _hub.StartAsync();
    }


    protected override async Task OnParametersSetAsync()
    {
        if (_hub == null)
            return;

        try
        {
            if (SessionId.HasValue)
            {
                if (SessionManager.ActiveSession != null && SessionManager.ActiveSession.Id != SessionId.Value)
                {
                    if (_hub.State == HubConnectionState.Connected)
                    {
                        await _hub.InvokeAsync("LeaveSession", SessionManager.ActiveSession.Id);
                    }
                }

                if (_hub.State == HubConnectionState.Connected)
                {
                    await _hub.InvokeAsync("JoinSession", SessionId.Value);
                }

                if (SessionManager.ActiveSession?.Id != SessionId.Value)
                {
                    await SessionManager.SetActiveAsync(SessionId.Value);
                    _scrollIntent = ScrollIntent.ForceScroll;
                }
                _shouldFocusChatInput = true;
            }
            else if (SessionManager.ActiveSession != null)
            {
                if (_hub.State == HubConnectionState.Connected)
                {
                    await _hub.InvokeAsync(
                        "LeaveSession",
                        SessionManager.ActiveSession.Id);
                }

                SessionManager.ClearActive();
                _shouldFocusChatInput = true;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error during session parameter change for SessionId={SessionId}", SessionId);
        }
    }


    public async ValueTask DisposeAsync()
    {
        SessionManager.OnChange -= StateHasChanged;
        _cts?.Cancel();
        _cts?.Dispose();
        
        if (_hub != null)
            await _hub.DisposeAsync();
    }


    private async Task Send()
    {
        if (_isSending || string.IsNullOrWhiteSpace(UserInput))
            return;
            
        if (_assistantTyping)
        {
            StopGeneration();
            // allow a brief moment for state changes to propagate
            await Task.Yield();
        }

        _isSending = true;
        var userMessage = UserInput;
        UserInput = "";

        try { await JS.InvokeVoidAsync("chatScroll.resetAutoResize", _chatInputRef); } catch { }

        bool isNewSession = SessionManager.ActiveSession == null;

        if (isNewSession)
        {
            await SessionManager.CreateSessionAsync(userMessage);
            if (_hub!.State == HubConnectionState.Connected)
            {
                await _hub.InvokeAsync(
                    "JoinSession",
                    SessionManager.ActiveSession!.Id);
            }
        }
            var userMsg = SessionManager.AddMessageInMemory(ChatRole.User, userMessage);
            _scrollIntent = ScrollIntent.ForceScroll;
            await InvokeAsync(StateHasChanged);

            // Background tasks - handle thread safety with fresh scope
            var currentSessionId = SessionManager.ActiveSession!.Id;
            _ = Task.Run(async () =>
            {
                try 
                {
                    using var scope = ScopeFactory.CreateScope();
                    var repo = scope.ServiceProvider.GetRequiredService<IChatRepository>();

                    if (userMsg != null)
                    {
                        if (_hub != null && _hub.State == HubConnectionState.Connected)
                        {
                            await _hub.InvokeAsync("SendUserMessage", currentSessionId, userMsg.Id, userMessage);
                        }

                        var exists = await repo.MessageExistsAsync(userMsg.Id);
                        if (!exists) 
                        {
                            await repo.UpdateSessionTimeAndAddMessageAsync(currentSessionId, DateTime.UtcNow, new ChatMessage(userMsg.Role, userMsg.Content, currentSessionId) { Id = userMsg.Id, CreatedAt = userMsg.CreatedAt });
                        }
                    }
                }
                catch (Exception ex)
                {
                    Logger.LogError(ex, "Background persistence error (UserMsg) for session {SessionId}", currentSessionId);
                }
            });

            if (_hub!.State == HubConnectionState.Connected)
            {
                await _hub.InvokeAsync(
                    "AssistantTyping",
                    SessionManager.ActiveSession!.Id,
                    true);
            }

            _assistantTyping = true;
            _isSending = false; // RELEASE THE LOCK EARLY
            await InvokeAsync(StateHasChanged);

            _cts = new CancellationTokenSource();
            var currentToken = _cts.Token; // Capture local to this specific Send() invocation

            // Create assistant message immediately with empty content for streaming
            var assistantMsgId = Guid.NewGuid();
            SessionManager.AddMessageInMemory(ChatRole.Assistant, "", assistantMsgId);
            _isStreaming = true;
            _scrollIntent = ScrollIntent.ForceScroll;
            await InvokeAsync(StateHasChanged);

            var replyBuilder = new System.Text.StringBuilder();
            _streamRenderThrottle.Restart();
            TokenUsage? streamUsage = null;
            string? streamModel = null;

            try
            {
                await foreach (var chunk in ChatService.GetReplyStreamAsync(
                    SessionManager.ActiveSession.Messages, SelectedModel.Provider, SelectedModel.ModelId, currentToken))
                {
                    if (!string.IsNullOrEmpty(chunk.Text))
                    {
                        replyBuilder.Append(chunk.Text);
                        SessionManager.UpdateMessageContent(assistantMsgId, replyBuilder.ToString());
                    }

                    if (chunk.Usage != null)
                        streamUsage = chunk.Usage;
                    if (chunk.Model != null)
                        streamModel = chunk.Model;

                    // Throttle UI re-renders to ~50ms intervals
                    if (_streamRenderThrottle.ElapsedMilliseconds >= 50)
                    {
                        _scrollIntent = ScrollIntent.ForceScroll;
                        await InvokeAsync(StateHasChanged);
                        _streamRenderThrottle.Restart();
                    }
                }
            }
            catch (OperationCanceledException)
            {
                if (replyBuilder.Length == 0)
                    replyBuilder.Append("*(Generation stopped by user)*");
                else
                    replyBuilder.Append("\n\n*(Generation stopped by user)*");
                SessionManager.UpdateMessageContent(assistantMsgId, replyBuilder.ToString());
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "AI request failed for session {SessionId}", SessionManager.ActiveSession?.Id);
                if (replyBuilder.Length == 0)
                    replyBuilder.Append("**Error:** Something went wrong. Please try again.");
                else
                    replyBuilder.Append("\n\n**Error:** Something went wrong. Please try again.");
                SessionManager.UpdateMessageContent(assistantMsgId, replyBuilder.ToString());
            }

            _streamRenderThrottle.Stop();
            _isStreaming = false;
            _assistantTyping = false;
            if (_cts != null && _cts.Token == currentToken)
            {
                _cts.Dispose();
                _cts = null;
            }

            if (_hub.State == HubConnectionState.Connected)
            {
                await _hub.InvokeAsync(
                    "AssistantTyping",
                    SessionManager.ActiveSession.Id,
                    false);
            }

            var finalReply = replyBuilder.ToString();

            // Attach AiUsage to the in-memory message if we received usage data
            if (streamUsage != null)
            {
                var assistantMsg = SessionManager.ActiveSession.Messages.FirstOrDefault(m => m.Id == assistantMsgId);
                if (assistantMsg != null)
                {
                    assistantMsg.AiUsage = new AiUsage
                    {
                        ChatMessageId = assistantMsgId,
                        Provider = SelectedModel.Provider,
                        PromptTokens = streamUsage.PromptTokens,
                        CompletionTokens = streamUsage.CompletionTokens,
                        TotalTokens = streamUsage.TotalTokens,
                        Model = streamModel ?? SelectedModel.ModelId,
                    };
                }
            }

            _scrollIntent = ScrollIntent.ForceScroll;
            _shouldFocusChatInput = true;
            await InvokeAsync(StateHasChanged);

            // Capture AiUsage for background persistence
            var aiUsageForPersist = streamUsage != null ? new AiUsage
            {
                ChatMessageId = assistantMsgId,
                Provider = SelectedModel.Provider,
                PromptTokens = streamUsage.PromptTokens,
                CompletionTokens = streamUsage.CompletionTokens,
                TotalTokens = streamUsage.TotalTokens,
                Model = streamModel ?? SelectedModel.ModelId,
            } : null;

            _ = Task.Run(async () =>
            {
                try 
                {
                    using var scope = ScopeFactory.CreateScope();
                    var repo = scope.ServiceProvider.GetRequiredService<IChatRepository>();

                    if (_hub != null && _hub.State == HubConnectionState.Connected)
                    {
                        await _hub.InvokeAsync("SendAssistantMessage", currentSessionId, assistantMsgId, finalReply);
                    }

                    var exists = await repo.MessageExistsAsync(assistantMsgId);
                    if (!exists) 
                    {
                        var msgToSave = new ChatMessage(ChatRole.Assistant, finalReply, currentSessionId) { Id = assistantMsgId };
                        msgToSave.AiUsage = aiUsageForPersist;
                        await repo.UpdateSessionTimeAndAddMessageAsync(currentSessionId, DateTime.UtcNow, msgToSave);
                    }
                }
                catch (Exception ex)
                {
                    Logger.LogError(ex, "Background persistence error (AssistantMsg) for session {SessionId}", currentSessionId);
                }
            });

            if (isNewSession)
            {
                Nav.NavigateTo(
                    $"/chat/{SessionManager.ActiveSession.Id}",
                    forceLoad: false);
            }
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
            await Send();
    }

    private async Task JumpToLatest()
    {
        _showJumpToLatest = false;
        _scrollIntent = ScrollIntent.ForceScroll;
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnMessagesScrolled()
    {
        var nearBottom = await JS.InvokeAsync<bool>(
            "chatScroll.isNearBottom", _messagesRef);

        if (!nearBottom)
        {
            _showJumpToLatest = true;
        }
        else
        {
            _showJumpToLatest = false;
        }

        await InvokeAsync(StateHasChanged);
    }



    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try { await JS.InvokeVoidAsync("chatScroll.initAutoResize", _chatInputRef); } catch { }
        }

        if (_shouldFocusChatInput && !_isSending && !IsReadOnly())
        {
            _shouldFocusChatInput = false;
            try { await _chatInputRef.FocusAsync(); } catch { }
        }

        if (_scrollIntent == ScrollIntent.None)
        {
            try { await JS.InvokeVoidAsync("chatScroll.formatCodeBlocks"); } catch { }
            return;
        }

        await Task.Yield();

        if (_scrollIntent == ScrollIntent.ForceScroll)
        {
            await JS.InvokeVoidAsync("chatScroll.scrollToBottom", _messagesRef);
            _showJumpToLatest = false;
        }

        try { await JS.InvokeVoidAsync("chatScroll.formatCodeBlocks"); } catch { }

        _scrollIntent = ScrollIntent.None;
    }

    private async Task RegenerateLast()
    {
        var session = SessionManager.ActiveSession;
        if (session == null) return;
        var currentSessionId = session.Id;

        // 1. Find last assistant message
        var lastAssistant = session.Messages.LastOrDefault(m => m.Role == ChatRole.Assistant);
        if (lastAssistant == null) return;

        // 2. Remove it (memory)
        session.Messages.Remove(lastAssistant);

        // 3. Remove it (DB)
        await SessionManager.DeleteMessageAsync(lastAssistant.Id);

        await InvokeAsync(StateHasChanged);

        // 4. Re-send conversation (same as Send(), minus user message)
        _assistantTyping = true;
        await InvokeAsync(StateHasChanged);

        _cts = new CancellationTokenSource();

        // Create assistant message immediately with empty content for streaming
        var assistantMsgId = Guid.NewGuid();
        SessionManager.AddMessageInMemory(ChatRole.Assistant, "", assistantMsgId);
        _isStreaming = true;
        _scrollIntent = ScrollIntent.ForceScroll;
        await InvokeAsync(StateHasChanged);

        var replyBuilder = new System.Text.StringBuilder();
        _streamRenderThrottle.Restart();
        TokenUsage? streamUsage = null;
        string? streamModel = null;

        try
        {
            await foreach (var chunk in ChatService.GetReplyStreamAsync(session.Messages, SelectedModel.Provider, SelectedModel.ModelId, _cts.Token))
            {
                if (!string.IsNullOrEmpty(chunk.Text))
                {
                    replyBuilder.Append(chunk.Text);
                    SessionManager.UpdateMessageContent(assistantMsgId, replyBuilder.ToString());
                }

                if (chunk.Usage != null)
                    streamUsage = chunk.Usage;
                if (chunk.Model != null)
                    streamModel = chunk.Model;

                // Throttle UI re-renders to ~50ms intervals
                if (_streamRenderThrottle.ElapsedMilliseconds >= 50)
                {
                    _scrollIntent = ScrollIntent.ForceScroll;
                    await InvokeAsync(StateHasChanged);
                    _streamRenderThrottle.Restart();
                }
            }
        }
        catch (OperationCanceledException)
        {
            if (replyBuilder.Length == 0)
                replyBuilder.Append("*(Generation stopped by user)*");
            else
                replyBuilder.Append("\n\n*(Generation stopped by user)*");
            SessionManager.UpdateMessageContent(assistantMsgId, replyBuilder.ToString());
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Regenerate AI request failed for session {SessionId}", currentSessionId);
            if (replyBuilder.Length == 0)
                replyBuilder.Append("**Error:** Something went wrong. Please try again.");
            else
                replyBuilder.Append("\n\n**Error:** Something went wrong. Please try again.");
            SessionManager.UpdateMessageContent(assistantMsgId, replyBuilder.ToString());
        }
        finally
        {
            _cts.Dispose();
            _cts = null;
        }

        _streamRenderThrottle.Stop();
        _isStreaming = false;
        _assistantTyping = false;

        var finalReply = replyBuilder.ToString();

        // Attach AiUsage to the in-memory message if we received usage data
        if (streamUsage != null)
        {
            var assistantMsg = session.Messages.FirstOrDefault(m => m.Id == assistantMsgId);
            if (assistantMsg != null)
            {
                assistantMsg.AiUsage = new AiUsage
                {
                    ChatMessageId = assistantMsgId,
                    Provider = SelectedModel.Provider,
                    PromptTokens = streamUsage.PromptTokens,
                    CompletionTokens = streamUsage.CompletionTokens,
                    TotalTokens = streamUsage.TotalTokens,
                    Model = streamModel ?? SelectedModel.ModelId,
                };
            }
        }

        _scrollIntent = ScrollIntent.ForceScroll;
        _shouldFocusChatInput = true;
        await InvokeAsync(StateHasChanged);

        // Capture AiUsage for background persistence
        var aiUsageForPersist = streamUsage != null ? new AiUsage
        {
            ChatMessageId = assistantMsgId,
            Provider = SelectedModel.Provider,
            PromptTokens = streamUsage.PromptTokens,
            CompletionTokens = streamUsage.CompletionTokens,
            TotalTokens = streamUsage.TotalTokens,
            Model = streamModel ?? SelectedModel.ModelId,
        } : null;

        _ = Task.Run(async () =>
        {
            try 
            {
                using var scope = ScopeFactory.CreateScope();
                var repo = scope.ServiceProvider.GetRequiredService<IChatRepository>();

                if (_hub != null && _hub.State == HubConnectionState.Connected)
                {
                    await _hub.InvokeAsync("SendAssistantMessage", currentSessionId, assistantMsgId, finalReply);
                }

                var exists = await repo.MessageExistsAsync(assistantMsgId);
                if (!exists) 
                {
                    var msgToSave = new ChatMessage(ChatRole.Assistant, finalReply, currentSessionId) { Id = assistantMsgId };
                    msgToSave.AiUsage = aiUsageForPersist;
                    await repo.UpdateSessionTimeAndAddMessageAsync(currentSessionId, DateTime.UtcNow, msgToSave);
                }
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Background persistence error (Regenerate) for session {SessionId}", currentSessionId);
            }
        });
    }

    private string ToHtml(string content)
    {
        if (string.IsNullOrWhiteSpace(content)) return "";
        var pipeline = new MarkdownPipelineBuilder().Build();
        return Markdown.ToHtml(content, pipeline);
    }

    private ChatMessage? GetLastAssistantMessage()
    {
        return SessionManager.ActiveSession?
            .Messages
            .LastOrDefault(m => m.Role == ChatRole.Assistant);
    }

    private void StopGeneration()
    {
        _cts?.Cancel();
        _assistantTyping = false;
        StateHasChanged();
    }

    private async Task CopyToClipboard(string text)
    {
        await JS.InvokeVoidAsync("chatScroll.copyText", text);
        ToastService.ShowToast("Copied safely to clipboard", "success");
    }


    private enum ScrollIntent
    {
        None,
        ForceScroll
    }

}